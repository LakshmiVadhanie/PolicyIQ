# ============================================================
# PolicyIQ — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ---- Google Cloud ----
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCP_LOCATION=us-central1

# ---- Vertex AI ----
VERTEX_AI_MODEL=gemini-1.5-pro
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ---- BigQuery ----
BIGQUERY_DATASET=policyiq_analytics
BIGQUERY_INTERACTIONS_TABLE=interactions
BIGQUERY_METRICS_TABLE=evaluation_metrics
BIGQUERY_ROUTING_TABLE=agent_routing_log

# ---- App Config ----
APP_ENV=development          # development | staging | production
LOG_LEVEL=INFO
PORT=8080

# ---- Agent Config ----
SUPERVISOR_MODEL=gemini-1.5-pro
SPECIALIST_MODEL=gemini-1.5-flash
CONFIDENCE_THRESHOLD=0.75
MAX_AGENT_ITERATIONS=5

# ---- RAGAS Quality Gate ----
RAGAS_FAITHFULNESS_THRESHOLD=0.70
RAGAS_RELEVANCY_THRESHOLD=0.70
RAGAS_COMPOSITE_THRESHOLD=0.70

# ---- Mock Mode (set to true for local dev without GCP) ----
USE_MOCK_LLM=true
USE_MOCK_BIGQUERY=true
